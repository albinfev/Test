[{"name":"app.R","content":"library(shiny)\r\nlibrary(FactoMineR)\r\n\r\nif (!exists(\"questionnaire\")) {\r\n  questionnaire <- readRDS(\"questionnaire.rds\")\r\n}\r\n\r\n# ============================================================\r\n# Mini app de test — FactoMineR::PCA()\r\n# ============================================================\r\n\r\ncases <- list(\r\n  pca = list(\r\n    code = \"\r\nif (!exists('questionnaire')) {\r\n  questionnaire <- readRDS('questionnaire.rds')\r\n}\r\n\r\nif (!requireNamespace('FactoMineR', quietly = TRUE)) {\r\n  stop('FactoMineR non disponible.')\r\n}\r\n\r\nvariables_qualitatives <- intersect(\r\n  c('type_produit', 'budget_contraint', 'sexe', 'age_classe', 'lieu_achat', 'profil_alim'),\r\n  names(questionnaire)\r\n)\r\nquestionnaire[variables_qualitatives] <- lapply(questionnaire[variables_qualitatives], factor)\r\n\r\nnoms_variables <- names(questionnaire)\r\nvar_actives_noms <- noms_variables[2:20]\r\n\r\ncat('Dimensions du questionnaire :', nrow(questionnaire), 'x', ncol(questionnaire), '\\\\n')\r\ncat('Variables actives :\\\\n')\r\nprint(var_actives_noms)\r\n\r\nvar_actives <- questionnaire[, var_actives_noms]\r\n\r\ncat('\\\\nDimensions du tableau actif :', nrow(var_actives), 'x', ncol(var_actives), '\\\\n')\r\n\r\nres_pca <- FactoMineR::PCA(\r\n  var_actives,\r\n  scale.unit = TRUE,\r\n  ncp        = 5,\r\n  graph      = FALSE\r\n)\r\n\r\ncat('\\\\nValeurs propres et inertie expliquée (5 premiers axes) :\\\\n')\r\nprint(round(res_pca$eig[1:5, ], 3))\r\n\r\ncat('\\\\nCoordonnées des variables sur les 2 premiers axes :\\\\n')\r\nprint(round(res_pca$var$coord[, 1:2], 3))\r\n\r\ncat('\\\\nQualité de représentation des variables (cos2) :\\\\n')\r\nprint(round(res_pca$var$cos2[, 1:2], 3))\r\n\"\r\n  )\r\n)\r\n\r\neval_code_capture <- function(code, envir = .GlobalEnv) {\r\n  old_width <- getOption(\"width\")\r\n  on.exit(options(width = old_width), add = TRUE)\r\n  options(width = 160)\r\n  exprs <- parse(text = code)\r\n  out <- character()\r\n  for (expr in exprs) {\r\n    one <- capture.output({\r\n      withCallingHandlers({\r\n        res <- withVisible(eval(expr, envir = envir))\r\n        if (isTRUE(res$visible) && !is.null(res$value)) print(res$value)\r\n      },\r\n      message = function(m) { cat(conditionMessage(m), \"\\n\"); invokeRestart(\"muffleMessage\") },\r\n      warning = function(w) { cat(\"Warning: \", conditionMessage(w), \"\\n\", sep = \"\"); invokeRestart(\"muffleWarning\") })\r\n    })\r\n    out <- c(out, one)\r\n  }\r\n  paste(out, collapse = \"\\n\")\r\n}\r\n\r\nui <- fluidPage(\r\n  h3(\"Mini test — FactoMineR::PCA()\"),\r\n  br(),\r\n  fluidRow(\r\n    column(6,\r\n           h4(\"Code\"),\r\n           verbatimTextOutput(\"code_affiche\")\r\n    ),\r\n    column(6,\r\n           h4(\"Sortie console\"),\r\n           div(style = \"height:600px; overflow-y:auto; overflow-x:auto;\",\r\n               verbatimTextOutput(\"sortie\"))\r\n    )\r\n  ),\r\n  br(),\r\n  actionButton(\"executer\", \"Exécuter\", class = \"btn-success\")\r\n)\r\n\r\nserver <- function(input, output, session) {\r\n  \r\n  sortie_text <- reactiveVal(\"Cliquez sur Exécuter.\")\r\n  \r\n  output$code_affiche <- renderText({\r\n    cases$pca$code\r\n  })\r\n  \r\n  observeEvent(input$executer, {\r\n    result <- tryCatch(\r\n      eval_code_capture(cases$pca$code, envir = .GlobalEnv),\r\n      error = function(e) paste(\"Erreur :\", conditionMessage(e))\r\n    )\r\n    sortie_text(result)\r\n  })\r\n  \r\n  output$sortie <- renderText({\r\n    sortie_text()\r\n  })\r\n}\r\n\r\nshinyApp(ui, server)","type":"text"},{"name":"questionnaire.rds","content":"H4sIAAAAAAAABt2dCZhk13XXa6a7xxpNz6hn1ywa1ZhlgFjCdhwT1lFCFhAKBEggrENNd/Wo\nRHdXq6p6IrOGLWxhcQATxyHEchR7ZEu2FmsbWZLVtoxlC4eYJEDCvu/KBx8f/vBncV7V+Z+u\n/tV7PdVVtxZlvu9M9XvvvnvPPds999xz7/uem0ul0kxpdp/9P2d/lua++7u+7Y5vtKujdnHG\n4KDB6wZ7DPa2C5dKs1lBA3ur9BaDmwz2G2SVHTCY9/cOGdxisGBw2OCIQVbvMYPjBicMThrc\nanDK4LS3edbgNoNzBrcblA3OG7zV4JcY/FKDX2bwyw0uGPw